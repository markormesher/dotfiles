{
  "position": "top",
  "spacing": 4,
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "sway/window"
  ],
  "modules-right": [
    "custom/needs-reboot",
    "wireplumber",
    "backlight",
    "battery",
    "sway/language",
    "tray",
    "clock"
  ],

  "sway/workspaces": {},
  "sway/mode": {
    "format": "َ±گ‹ {}"
  },
  "swap/window": {
    "max-length": 50
  },

  "custom/needs-reboot": {
    "exec": "~/.config/waybar/needs-reboot.sh",
    "interval": 600,
    "return-type": "json",
    "hide-empty-text": true
  },

  "wireplumber": {
    "format": "َ°•¾ {volume}%",
    "format-muted": "َ°¸ˆ {volume}%",
    "on-click": "helvum"
  },
  "backlight": {
    "format": "َ°Œµ {percent}%",
    "on-click": "~/.config/waybar/toggle-theme.sh",
  },
  "battery": {
    "format-charging": "َ°ڑ¥ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-discharging": "{icon} {capacity}% ({time})",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "format-time": "{H}:{m}"
  },
  "sway/language": {
    "format": "{short}",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },
  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  },
  "tray": {
    "expand": true,
    "spacing": 4
  }
}
